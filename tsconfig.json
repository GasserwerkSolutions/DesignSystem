{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "rootDir": "./js",
    "outDir": "./dist/js",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "removeComments": false
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist", "scripts", "tests"]
}
